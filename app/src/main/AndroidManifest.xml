<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!--
        Android 11+ package visibility: targetSdk 33 means we have to declare every
        package we want to bindService / startActivity against. com.syu.ms hosts the
        toolkit binder we drive the tuner through; com.syu.carradio is the stock
        radio activity we launch for the ON AIR source switch.
    -->
    <queries>
        <package android:name="com.syu.ms" />
        <package android:name="com.syu.carradio" />
    </queries>

    <application
        android:label="@string/app_name"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:allowBackup="false"
        android:supportsRtl="true"
        android:theme="@style/Theme.FytRadio">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:screenOrientation="portrait"
            android:configChanges="orientation|screenSize|keyboardHidden">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>
</manifest>
